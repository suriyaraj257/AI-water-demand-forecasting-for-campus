# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/campus_water_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=campus_water_db
DB_USER=user
DB_PASSWORD=password

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Weather API
WEATHER_API_KEY=your_openweathermap_api_key
WEATHER_CITY=your_city_name

# Telegram Bot (for automation alerts)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# n8n Webhook
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Model Configuration
MODEL_PATH=models/water_forecast_model.pkl
LSTM_MODEL_PATH=models/water_forecast_lstm.h5

# Alert Thresholds
TANK_LOW_THRESHOLD=20
TANK_HIGH_THRESHOLD=95
SPIKE_DETECTION_MULTIPLIER=2.0
